{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "jsx": "react-jsx",

    "lib": ["dom", "dom.iterable", "es2020"],

    "allowJs": true,
    "checkJs": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "strict": false
  },
  "include": ["src"]
}